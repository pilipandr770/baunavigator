# ─── Flask ───────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string-min-32-chars

# ─── Database (Render PostgreSQL) ────────────────────
# Формат: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/baunavigator

# ─── Anthropic Claude API ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe (монетизация) ─────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EXPERT=price_...

# ─── Mail (для уведомлений) ───────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@baunavigator.de

# ─── Геопортал Гессен (опционально для MVP) ───────────
HESSEN_WFS_URL=https://geodaten.hessen.de/geoserver/wfs

# ─── Приложение ───────────────────────────────────────
APP_NAME=BauNavigator
APP_URL=http://localhost:5000
DEFAULT_LAND=HE
